---
export interface Props {
  title: string;
  description: string;
  imageUrl: string;
  author: string;
  authorUser: string;
  link: string;
}

const { title, description, imageUrl, author, authorUser, link } = Astro.props;
---

<article
  class="group relative flex h-full flex-col overflow-hidden rounded-2xl border border-white/10 bg-white shadow-xl shadow-violet-950/30 transition duration-300 hover:-translate-y-1.5 hover:border-violet-300/60 hover:shadow-2xl hover:shadow-violet-900/40"
>
  <!-- Imagen con leve overlay -->
  <div class="relative h-44 overflow-hidden">
    <img
      src={imageUrl}
      alt={`Imagen de ${title}`}
      class="h-full w-full object-cover transition duration-500 group-hover:scale-110"
      loading="lazy"
      decoding="async"
    />
    <div
      class="absolute inset-0 bg-gradient-to-t from-black/35 via-transparent to-transparent"
    >
    </div>
  </div>

  <div class="flex flex-1 flex-col p-6">
    <!-- Autor -->
    <div class="mb-4 flex items-center gap-3">
      <a
        href={"https://github.com/" + authorUser}
        target="_blank"
        rel="noopener noreferrer"
      >
        <img
          class="inline-block h-10 w-10 rounded-full border-2 border-slate-200 ring-2 ring-white transition duration-300 hover:border-violet-500"
          src={`https://github.com/${authorUser}.png`}
          alt={`Avatar de ${author}`}
        />
      </a>
      <span class="text-sm font-semibold text-slate-500">{author}</span>
    </div>

    <h2 class="mb-2 text-lg font-bold leading-snug text-slate-900">{title}</h2>
    <p class="mb-5 flex-1 text-sm leading-relaxed text-slate-600">
      {description}
    </p>

    <a
      href={link}
      class="mt-auto inline-flex items-center justify-center gap-1.5 rounded-xl bg-gradient-to-r from-violet-600 to-fuchsia-600 px-4 py-2.5 text-sm font-semibold text-white shadow-md shadow-violet-600/30 transition hover:from-violet-500 hover:to-fuchsia-500 hover:shadow-lg hover:shadow-violet-500/40"
    >
      Ver actividad
      <svg
        class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="2"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
      </svg>
    </a>
  </div>
</article>
