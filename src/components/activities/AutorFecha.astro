---
export interface Props {
  author: string;
  authorUser: string;
  date: string;
}

const { author, authorUser, date } = Astro.props;
---

<div class="mt-5 flex items-center justify-center gap-3 text-sm">
  <a
    href={"https://github.com/" + authorUser}
    target="_blank"
    rel="noopener noreferrer"
  >
    <img
      class="inline-block h-10 w-10 rounded-full border-2 border-white/20 ring-2 ring-white/10 transition duration-300 hover:border-violet-500"
      src={`https://github.com/${authorUser}.png`}
      alt={`Avatar de ${author}`}
    />
  </a>

  <p class="font-medium text-slate-200">{author}</p>
  <span class="h-1 w-1 rounded-full bg-violet-400"></span>
  <p class="text-slate-400">{date}</p>
</div>
