---
import Layout from "../layouts/Layout.astro";
import { articles } from "../utils/actividadesData.ts";
import ActividadCard from "../components/cards/ActividadCard.astro";
import Avatars from "../components/Avatars.astro";

const images: Record<string, { default: { src: string } }> = import.meta.glob(
  "/src/assets/imagenesActividades/*",
  { eager: true }
);
---

<Layout>
  <header class="mx-auto mt-2 mb-10 max-w-3xl text-center">
    <span
      class="inline-flex items-center gap-2 rounded-full border border-violet-400/30 bg-violet-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-violet-200"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-fuchsia-400"></span>
      Asignatura
    </span>
    <h1 class="mt-4 text-3xl font-bold text-white sm:text-4xl">
      Análisis y Diseño de Sistemas
    </h1>
    <p class="mt-3 text-slate-400">
      Actividades, consultas y entregables desarrollados por el equipo durante
      la asignatura.
    </p>
    <div
      class="mx-auto mt-5 h-1 w-24 rounded-full bg-gradient-to-r from-violet-500 to-fuchsia-500"
    >
    </div>
  </header>

  <div
    class="mx-auto grid max-w-6xl grid-cols-1 gap-6 p-4 sm:grid-cols-2 lg:grid-cols-3"
  >
    {
      articles.map((article) => (
        <ActividadCard
          title={article.title}
          description={article.description}
          imageUrl={images[`/src/assets/${article.imageUrl}`]?.default.src}
          author={article.author.name}
          authorUser={article.author.user}
          link={article.link}
        />
      ))
    }
  </div>
  <Avatars />
</Layout>
